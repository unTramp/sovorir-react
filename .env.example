# Dev mode uses the mock API by default unless you explicitly disable it.
VITE_USE_MOCK_API=true

# Set this when you want to test against a real backend.
VITE_API_URL=http://localhost:3000

# Local AI helpers (never expose these in client-side code)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides for the local AI scripts
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
